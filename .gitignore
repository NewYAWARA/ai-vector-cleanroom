# byte code / caches
__pycache__/
.pytest_cache/
*.py[cod]

# virtual envs
.venv/
venv/
env/

# embedded/portable interpreter (never commit)
python/

# working folders — keep the dirs, ignore contents
input/*
!input/.gitkeep
output/*
!output/.gitkeep

# test fixtures are regenerated by tests/generate_fixtures.py
tests/fixtures/
tests/_*/

# build / release scratch
release_work/
release_staging*/
release_validation_extract*/
staging/
real_world_validation/

# packaged output & logs
*.zip
*.log
.DS_Store
Thumbs.db
